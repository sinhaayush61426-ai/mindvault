# MindVault Configuration - Copy to .env for local development

# Flask Configuration
FLASK_ENV=development
DEBUG=False
SECRET_KEY=change-me-to-a-secure-random-key-in-production

# Database
DATABASE_URL=sqlite:///instance/database.db

# Encryption (Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-base64-fernet-key-here

# Security
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_SYMBOLS=True
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_TIMEOUT=900

# Session
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=604800

# Content Limits
MAX_ENTRY_LENGTH=1000000
MAX_CHARACTER_NAME=100
MAX_CHARACTER_FIELD=5000
MAX_REVIEW_LENGTH=1000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/mindvault.log
